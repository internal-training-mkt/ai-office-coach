const routeOrder=['home','learn','prompt','workshop','practice'];
const lang=()=>document.querySelector('.ui-language select')?.value||'English';
const tr=()=>T[lang()]||T.English;
const esc=s=>String(s).replace(/[&<>"']/g,c=>({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#39;"}[c]));
let route='',lastLang='';
function nativeGo(r){const nav=document.querySelector('.portal-nav'),menus=nav?.querySelectorAll('.nav-menu');if(!nav||!menus)return;if(r==='home')nav.querySelector(':scope > button')?.click();else{const i={learn:0,prompt:1,workshop:2,practice:3}[r];const menu=menus[i];(menu?.querySelector('.nav-dropdown button')||menu?.querySelector(':scope > button'))?.click();}route=r;document.body.dataset.uxRoute25=r;location.hash=r==='prompt'?'tasks':r;setTimeout(()=>{enhance(true);scrollTo({top:0,behavior:'smooth'})},80)}
function detect(){if(route)return route;if(!document.querySelector('.portal-home')?.classList.contains('view-hidden'))return'home';if(!document.querySelector('.tasks-section')?.classList.contains('view-hidden'))return'prompt';if(!document.querySelector('.learning-centre')?.classList.contains('view-hidden'))return'learn';if(location.hash.includes('practice'))return'practice';return'workshop'}
function menu(){const w=tr();let d=document.querySelector('.ux-drawer25');if(!d){d=document.createElement('aside');d.className='ux-drawer25';d.innerHTML='<button class="ux-drawer-close25" type="button">×</button><div class="ux-drawer-brand25"><b>AI OFFICE COACH</b><small>MICROSOFT COPILOT WORKSHOP</small></div><nav></nav>';document.body.append(d);const s=document.createElement('button');s.className='ux-drawer-scrim25';s.type='button';document.body.append(s);s.onclick=()=>toggleMenu(false);d.querySelector('.ux-drawer-close25').onclick=()=>toggleMenu(false);d.addEventListener('click',e=>{const b=e.target.closest('[data-route]');if(b){nativeGo(b.dataset.route);toggleMenu(false)}});document.addEventListener('keydown',e=>{if(e.key==='Escape')toggleMenu(false)});document.addEventListener('click',e=>{if(e.target.closest('.mobile-nav-button')){e.preventDefault();e.stopImmediatePropagation();toggleMenu()}},true)}d.querySelector('nav').innerHTML=w.nav.map((x,i)=>`<button type="button" data-route="${routeOrder[i]}" class="${routeOrder[i]===route?'active':''}"><span>0${i+1}</span><b>${esc(x)}</b><i>→</i></button>`).join('');d.querySelector('.ux-drawer-close25').setAttribute('aria-label',w.close);document.querySelector('.mobile-nav-button span')?.replaceChildren(document.createTextNode(w.menu))}
function toggleMenu(v){const d=document.querySelector('.ux-drawer25');if(!d)return;const open=v===undefined?!d.classList.contains('open'):v;d.classList.toggle('open',open);document.querySelector('.ux-drawer-scrim25')?.classList.toggle('open',open)}
function heroHost(r){return r==='home'?document.querySelector('.portal-home'):r==='learn'?document.querySelector('.learning-centre'):r==='prompt'?document.querySelector('.tasks-section'):r==='workshop'?document.querySelector('.training-hub'):document.querySelector('.practice-lab')}
function hero(){const w=tr(),h=heroHost(route);if(!h)return;let x=h.querySelector(':scope > .ux-hero25');if(!x){x=document.createElement('section');x.className='ux-hero25';h.prepend(x)}const c=w.hero[route];x.innerHTML=`<div class="ux-hero-grid25" aria-hidden="true"></div><div class="ux-hero-orbit25" aria-hidden="true"><i>${route==='home'?'✦':route==='learn'?'4':route==='prompt'?'⌘':route==='workshop'?'M':'✓'}</i><span></span><span></span><span></span></div><div class="ux-hero-copy25"><small>${w.nav[routeOrder.indexOf(route)]}</small><h1>${esc(c[0])}</h1><p>${esc(c[1])}</p><button type="button" data-hero-action>${esc(c[2])} <b>→</b></button></div>${route==='learn'?`<ol class="ux-four25">${w.steps.map((s,i)=>`<li><em>${i+1}</em><span>${esc(s)}</span></li>`).join('')}</ol>`:''}`;x.querySelector('[data-hero-action]').onclick=()=>{if(route==='home')nativeGo('learn');else if(route==='learn')document.querySelector('.lesson-card')?.scrollIntoView({behavior:'smooth'});else if(route==='prompt')document.querySelector('.task-grid')?.scrollIntoView({behavior:'smooth'});else if(route==='workshop')document.querySelector('.training-hub .training-grid,.training-hub article')?.scrollIntoView({behavior:'smooth'});else document.querySelector('.ux-practice-grid25')?.scrollIntoView({behavior:'smooth'})}}
function bottom(){const w=tr(),h=heroHost(route);if(!h)return;let n=h.querySelector(':scope > .ux-chapter25');if(!n){n=document.createElement('section');n.className='ux-chapter25';h.append(n)}const i=routeOrder.indexOf(route),prev=routeOrder[Math.max(0,i-1)],next=routeOrder[Math.min(routeOrder.length-1,i+1)];n.innerHTML=`<div><small>${w.next}</small><h2>${esc(w.nav[Math.min(i+1,4)])}</h2></div><nav><button data-go="${prev}">← ${esc(w.previous)}</button><button data-go="home">⌂ ${esc(w.home)}</button><button data-top>↑ ${esc(w.top)}</button>${i<4?`<button class="primary" data-go="${next}">${esc(w.next)} →</button>`:''}</nav>`;n.querySelectorAll('[data-go]').forEach(b=>b.onclick=()=>nativeGo(b.dataset.go));n.querySelector('[data-top]').onclick=()=>scrollTo({top:0,behavior:'smooth'});if(n!==h.lastElementChild)h.append(n)}
function profile(){const w=tr(),builder=document.querySelector('.builder-section'),panel=document.querySelector('.prompt-panel');if(!builder||!panel)return;let s=builder.querySelector('.ux-profile25');if(!s){s=document.createElement('section');s.className='ux-profile25';builder.prepend(s)}let saved={};try{saved=JSON.parse(sessionStorage.getItem('uxProfile25')||'{}')}catch{}const di=Math.max(0,Number(saved.dept)||0),gi=Math.max(0,Number(saved.grade)||0),roleText=saved.role||w.roles[di];s.innerHTML=`<header><div><small>01 · ${esc(w.profile)}</small><h2>${esc(w.profile)}</h2><p>${esc(w.profileHint)}</p></div><span>✦</span></header><div class="ux-profile-fields25"><label>${esc(w.department)}<select data-profile="dept">${w.dept.map((x,i)=>`<option value="${i}" ${i===di?'selected':''}>${esc(x)}</option>`).join('')}</select></label><label>${esc(w.grade)}<select data-profile="grade">${w.grades.map((x,i)=>`<option value="${i}" ${i===gi?'selected':''}>${esc(x)}</option>`).join('')}</select></label><label>${esc(w.aiRole)}<input data-profile="role" value="${esc(roleText)}"></label></div>`;s.onchange=e=>{if(!e.target.matches('[data-profile]'))return;const d=Number(s.querySelector('[data-profile="dept"]').value),g=Number(s.querySelector('[data-profile="grade"]').value),role=s.querySelector('[data-profile="role"]');if(e.target.dataset.profile==='dept')role.value=w.roles[d];sessionStorage.setItem('uxProfile25',JSON.stringify({dept:d,grade:g,role:role.value}));updatePreview()};s.querySelector('[data-profile="role"]').oninput=()=>{sessionStorage.setItem('uxProfile25',JSON.stringify({dept:Number(s.querySelector('[data-profile="dept"]').value),grade:Number(s.querySelector('[data-profile="grade"]').value),role:s.querySelector('[data-profile="role"]').value}));updatePreview()};updatePreview()}
function profilePrompt(){const w=tr(),s=document.querySelector('.ux-profile25');if(!s)return'';const d=Number(s.querySelector('[data-profile="dept"]')?.value||0),g=Number(s.querySelector('[data-profile="grade"]')?.value||0),r=s.querySelector('[data-profile="role"]')?.value||w.roles[d];const lines={English:`[PROFESSIONAL PROFILE]\nUser department: ${w.dept[d]}\nUser position: ${w.grades[g]}\nYou are a ${r}.`,"繁體中文":`[專業設定]\n使用者部門：${w.dept[d]}\n使用者職位：${w.grades[g]}\n你是一位${r}。`,"简体中文":`[专业设置]\n用户部门：${w.dept[d]}\n用户职位：${w.grades[g]}\n你是一位${r}。`,"日本語":`[専門設定]\n利用者の部門：${w.dept[d]}\n利用者の役職：${w.grades[g]}\nあなたは${r}です。`,"한국어":`[전문 설정]\n사용자 부서: ${w.dept[d]}\n사용자 직위: ${w.grades[g]}\n당신은 ${r}입니다.`};return lines[lang()]||lines.English}
function updatePreview(){const panel=document.querySelector('.prompt-panel'),pre=panel?.querySelector('pre');if(!panel||!pre)return;let p=panel.querySelector('.ux-role-preview25');if(!p){p=document.createElement('pre');p.className='ux-role-preview25';pre.before(p)}p.textContent=profilePrompt();const b=panel.querySelector('.copy-button');if(b){b.innerHTML=`<span>${esc(tr().copy)}</span><b>→</b>`}}
function practice(){const w=tr(),host=document.querySelector('.practice-lab');if(!host)return;let s=host.querySelector('.ux-practice-select25');if(!s){s=document.createElement('section');s.className='ux-practice-select25';const hero=host.querySelector('.ux-hero25');hero?.after(s)}s.innerHTML=`<header><small>PRACTICE CENTRE</small><h2>${esc(w.practiceTitle)}</h2><p>${esc(w.practiceHint)}</p></header><div class="ux-practice-grid25">${w.missions.map((m,i)=>`<button type="button" data-mission="${i}"><i>${m[3]}</i><strong>${esc(m[0])}</strong><span>${esc(w.duration)} · ${esc(m[1])}</span><span>${esc(w.files)} · ${esc(m[2])}</span><b>${esc(w.start)} →</b></button>`).join('')}</div>`;s.querySelectorAll('[data-mission]').forEach(b=>b.onclick=()=>{const i=Number(b.dataset.mission);document.querySelectorAll('.exercise-card').forEach((c,j)=>{c.classList.toggle('ux-open',j===i);c.hidden=j!==i});document.querySelector('.practice-lab .exercise-card:not([hidden])')?.scrollIntoView({behavior:'smooth',block:'start'})})}
function goalLinks(){document.addEventListener('click',e=>{const g=e.target.closest('.ux-goal');if(!g)return;e.preventDefault();const text=g.innerText.toLowerCase();if(text.includes('safety')||text.includes('安全')||text.includes('安全')||text.includes('안전'))nativeGo('practice');else{nativeGo('prompt');setTimeout(()=>{const cards=[...document.querySelectorAll('.task-card')],key=text.includes('excel')?'excel':text.includes('presentation')||text.includes('簡報')||text.includes('演示')||text.includes('プレゼン')||text.includes('프레젠')?'powerpoint':text.includes('report')||text.includes('報告')||text.includes('报告')||text.includes('レポート')||text.includes('보고')?'word':text.includes('meeting')||text.includes('會議')||text.includes('会议')||text.includes('会議')||text.includes('회의')?'meeting':'email';cards.find(c=>c.innerText.toLowerCase().includes(key))?.click()},180)}},true)}
function intercept(){document.addEventListener('click',e=>{const copy=e.target.closest('.copy-button');if(copy){e.preventDefault();e.stopImmediatePropagation();const core=document.querySelector('.prompt-panel > pre:not(.ux-role-preview25)')?.innerText||'';navigator.clipboard?.writeText(`${profilePrompt()}\n\n${core}`);copy.innerHTML=`<span>${esc(tr().copied)}</span><b>✓</b>`;setTimeout(updatePreview,1400);return}const reset=e.target.closest('.prompt-actions button');if(reset&&!reset.dataset.uxConfirmed){e.preventDefault();e.stopImmediatePropagation();if(confirm(tr().reset)){reset.dataset.uxConfirmed='1';reset.click();delete reset.dataset.uxConfirmed}}},true)}
